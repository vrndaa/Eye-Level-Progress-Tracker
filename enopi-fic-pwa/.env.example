# Copy this file to `.env` and fill in your values to switch the app to LIVE mode
# (reads/writes a real Google Sheet). Leave `.env` absent and the app runs offline
# from the registry.json seed. See SETUP_GOOGLE_SHEETS.md for how to get these.
#
# `.env` is gitignored — never commit real values.

VITE_GOOGLE_CLIENT_ID=your-oauth-client-id.apps.googleusercontent.com
VITE_SPREADSHEET_ID=the-id-between-/d/-and-/edit-in-the-sheet-url
# Optional — only if you renamed the tab away from the POC default:
# VITE_SHEET_NAME=FIC Registry (POC data)
